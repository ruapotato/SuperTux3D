; ==================== VOLCANO (CSG) ====================
; A CSGCombiner3D that unions a stack of basalt blocks then subtracts
; a chamber sphere/box + crater + two tube vents. The exterior visible
; shape below is a red_rock cone skirt + stone_dark upper, with
; spiral ramp segments and a caldera lava plane — but the _interior
; voids_ are produced by CSG.

[node name="VolcanoCSG" type="CSGCombiner3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0)
use_collision = true
collision_layer = 1
collision_mask = 1

; Solid shell — big basalt mass (the "hill")
[node name="HillShell" type="CSGBox3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 6, 0)
size = Vector3(30, 14, 30)
material = ExtResource("Mat_RedRock")

; Carve out a large interior chamber (box void)
[node name="ChamberCarve" type="CSGBox3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3, 0)
size = Vector3(20, 6, 20)
operation = 2

; Carve out upper crater (sphere void from top)
[node name="CraterCarve" type="CSGSphere3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 13, 0)
radius = 3.6
operation = 2

; Carve a vertical vent connecting crater <-> chamber
[node name="VentCarve" type="CSGCylinder3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 8, 0)
radius = 2.0
height = 12
operation = 2

; Carve side-entrance cave at base (horizontal cylinder on +z side)
[node name="SideCaveCarve" type="CSGCylinder3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 0, 1, 0, -1, 0, 0, 3, 15)
radius = 2.4
height = 14
operation = 2

; Carve lava tube branch north (-z direction from chamber outward)
[node name="TubeNorthCarve" type="CSGCylinder3D" parent="VolcanoCSG"]
transform = Transform3D(1, 0, 0, 0, 0, 1, 0, -1, 0, 0, 3, -15)
radius = 2.2
height = 14
operation = 2

; Carve lava tube branch east (+x)
[node name="TubeEastCarve" type="CSGCylinder3D" parent="VolcanoCSG"]
transform = Transform3D(0, 0, 1, 0, 1, 0, -1, 0, 0, 15, 3, 0)
radius = 2.2
height = 14
operation = 2

