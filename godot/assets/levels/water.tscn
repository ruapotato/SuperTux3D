[gd_scene load_steps=60 format=3]

; WATER — Tropical lagoon with sunny beach above and reef/shipwreck below.
; Landmarks: curved Sandy Bay, tall rocky Spire Island (star on top),
;   half-sunk Pirate Shipwreck, Coral Shelf (y=-3), Deep Trench (y=-10),
;   Underwater Cave at spire base. LEVEL_WATER_Y = 0.
; Palette: sand/sand_deep, water_blue/water_deep, stone_grey, bark,
;   fabric_red (pirate sail), fabric_blue, wood_dark, wood_planks, gold.
; 14 enemies (piranha beach plants, goombas, koopas, sea-mine bobomb,
;   drifting cuttlefish, bobomb_buddy), ~30 yellow coins, 8 red coins,
;   2 stars, 2 one-ups, vanish cap on mast top, message-in-a-bottle.

