[gd_scene load_steps=140 format=3]

; WATER — Vast tropical lagoon with harbor, a massive tilted pirate galleon,
;   sunken temple ruins, coral reef tunnels, kelp forest, sea cave grotto,
;   and a lighthouse spire island. LEVEL_WATER_Y = 0.
; Hero piece: walkable pirate galleon (CSG interior: captain's cabin with
;   door cut through the stern, cargo hold below, hull breaches open to sea,
;   climbable mast crossbeams to crow's nest).
; Landmarks: Harbor with docks + lighthouse, Pirate Galleon, Sunken Temple
;   (drowned altar w/ crystal), Coral Tunnels, Kelp Forest (hidden passage),
;   Sea Cave grotto (stalactites + pool star), Spire Island + secondary
;   lighthouse (spiral ramp, room interior, star pedestal), Hidden Sandbar.
; Palette: sand/sand_deep, water_blue/water_deep, sandstone, stone_grey,
;   stone_dark, bark, leaves_green/dark, fabric_red/gold, wood_dark/planks,
;   gold, metal_grey, crystal_blue, emissive_cyan, petal_pink/purple.
; Enemies: 4 piranha (beach), 5 goomba, 3 koopa, 2 bobomb (sea mines),
;   5 cuttlefish (thematic), 2 bobomb_buddy. Content: 45 yellow coins,
;   8 red coins, 3 stars (lighthouse top / sea cave / temple altar),
;   4 one-ups, cap_vanish on mast top.

