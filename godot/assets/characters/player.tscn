[gd_scene load_steps=18 format=3 uid="uid://bptux01"]

; Tux-inspired penguin player rig. Larry Ewing placed the original Tux
; artwork in the public domain (with an attribution ask), so a penguin
; silhouette that borrows the general look is legally safe. Keeping the
; same 7-bone hierarchy (pelvis/torso/head/arm_l/arm_r/leg_l/leg_r) so
; clean_character_anim.gd drives the rig unchanged.

[sub_resource type="SphereMesh" id="head_mesh"]
radius = 0.22
height = 0.44
radial_segments = 16
rings = 10

[sub_resource type="StandardMaterial3D" id="black_mat"]
albedo_color = Color(0.07, 0.07, 0.09, 1)
shading_mode = 0

[sub_resource type="StandardMaterial3D" id="white_mat"]
albedo_color = Color(0.98, 0.98, 0.98, 1)
shading_mode = 0

[sub_resource type="StandardMaterial3D" id="orange_mat"]
albedo_color = Color(1.0, 0.62, 0.08, 1)
shading_mode = 0

[sub_resource type="StandardMaterial3D" id="eye_white_mat"]
albedo_color = Color(1, 1, 1, 1)
shading_mode = 0

[sub_resource type="StandardMaterial3D" id="pupil_mat"]
albedo_color = Color(0.05, 0.05, 0.1, 1)
shading_mode = 0

[sub_resource type="CapsuleMesh" id="body_mesh"]
radius = 0.27
height = 0.62
radial_segments = 14

; The white belly is a slightly flattened sphere in front of the body.
[sub_resource type="SphereMesh" id="belly_mesh"]
radius = 0.22
height = 0.52
radial_segments = 14
rings = 10

[sub_resource type="SphereMesh" id="eye_sphere"]
radius = 0.045
height = 0.09
radial_segments = 10
rings = 6

[sub_resource type="SphereMesh" id="pupil_sphere"]
radius = 0.02
height = 0.04
radial_segments = 8
rings = 6

; Beak: a small prism rotated so the narrow edge points forward.
[sub_resource type="PrismMesh" id="beak_mesh"]
size = Vector3(0.14, 0.07, 0.11)

; Wings (short flippers): flattened capsules sticking out from the body.
[sub_resource type="CapsuleMesh" id="wing_mesh"]
radius = 0.06
height = 0.32
radial_segments = 10

; Feet: orange blobs doubling as shoes.
[sub_resource type="BoxMesh" id="foot_mesh"]
size = Vector3(0.2, 0.08, 0.24)

; Leg: short thick segment. Tux's legs are stubby.
[sub_resource type="CapsuleMesh" id="leg_mesh"]
radius = 0.07
height = 0.22
radial_segments = 10

; Little highlight dots in the eyes (subtle).
[sub_resource type="SphereMesh" id="eye_spec"]
radius = 0.008
height = 0.016
radial_segments = 6
rings = 4

; Smile line — a thin dark box under the beak.
[sub_resource type="BoxMesh" id="smile_mesh"]
size = Vector3(0.08, 0.02, 0.015)

; The rig root is rotated 180° around Y so the authored +Z face ends up
; at Godot's forward (-Z). clean_character_anim doesn't touch this root.
[node name="Rig" type="Node3D"]
transform = Transform3D(-1, 0, 0, 0, 1, 0, 0, 0, -1, 0, 0, 0)

[node name="pelvis" type="Node3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.4, 0)

[node name="torso" type="Node3D" parent="pelvis"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.15, 0)

[node name="BodyMesh" type="MeshInstance3D" parent="pelvis/torso"]
mesh = SubResource("body_mesh")
surface_material_override/0 = SubResource("black_mat")

[node name="Belly" type="MeshInstance3D" parent="pelvis/torso"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.02, 0.12)
mesh = SubResource("belly_mesh")
surface_material_override/0 = SubResource("white_mat")

[node name="head" type="Node3D" parent="pelvis/torso"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.36, 0)

; The head stays a solid black sphere; no overlapping white belly on
; the front (previous attempt buried the eyes inside it). White is
; handled by a small chin-patch below the beak + the eye whites.
[node name="HeadMesh" type="MeshInstance3D" parent="pelvis/torso/head"]
mesh = SubResource("head_mesh")
surface_material_override/0 = SubResource("black_mat")

; Small flattened white chin patch, sitting just under the beak.
; Z-scale is tiny so it doesn't push out through the face features.
[node name="ChinPatch" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1.2, 0, 0, 0, 0.35, 0, 0, 0, 0.25, 0, -0.12, 0.18)
mesh = SubResource("belly_mesh")
surface_material_override/0 = SubResource("white_mat")

; Eyes are explicitly forward of the head sphere (z > 0.22 + radius)
; so no other mesh can occlude them from the front.
[node name="EyeL" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.06, 0.03, 0.21)
mesh = SubResource("eye_sphere")
surface_material_override/0 = SubResource("eye_white_mat")

[node name="EyeR" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.06, 0.03, 0.21)
mesh = SubResource("eye_sphere")
surface_material_override/0 = SubResource("eye_white_mat")

[node name="PupilL" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.06, 0.03, 0.24)
mesh = SubResource("pupil_sphere")
surface_material_override/0 = SubResource("pupil_mat")

[node name="PupilR" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.06, 0.03, 0.24)
mesh = SubResource("pupil_sphere")
surface_material_override/0 = SubResource("pupil_mat")

[node name="Beak" type="MeshInstance3D" parent="pelvis/torso/head"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.04, 0.235)
mesh = SubResource("beak_mesh")
surface_material_override/0 = SubResource("orange_mat")

; Wings/flippers. Rotated so they hang down along the body sides.
[node name="arm_l" type="Node3D" parent="pelvis/torso"]
