[gd_scene load_steps=3 format=3 uid="uid://bcuttle02"]

; Cuttlefish visual — real rigged mesh imported from assets/enemies/cuttle.glb
; (origin: the cuttle_fighter prototype). Wrapped in an EnemyVisual Node3D root
; so enemy.gd._build_visual() can instance it, rotate 180° around Y, and
; add its own collision/hurt shapes. The imported GLB also brings an
; AnimationPlayer with two clips ("defualt", "idel_loop") which we autoplay
; via a small bootstrap script below.

[ext_resource type="PackedScene" path="res://assets/enemies/cuttle.glb" id="1_glb"]

[sub_resource type="GDScript" id="boot_script"]
script/source = "extends Node3D
# Autoplay the imported 'idel_loop' animation so the cuttlefish drifts on
# screen — without this it imports in bind pose and looks frozen. The GLB
# was authored with a typo (\"idel_loop\"), so keep that spelling.
func _ready() -> void:
	var ap := _find_animation_player(self)
	if ap == null:
		return
	var names := ap.get_animation_list()
	if names.has(&\"idel_loop\"):
		ap.play(&\"idel_loop\")
	elif names.size() > 0:
		ap.play(names[0])

static func _find_animation_player(n: Node) -> AnimationPlayer:
	if n is AnimationPlayer:
		return n
	for c in n.get_children():
		var r := _find_animation_player(c)
		if r != null:
			return r
	return null
"

[node name="EnemyVisual" type="Node3D"]
script = SubResource("boot_script")

[node name="CuttleMesh" parent="." instance=ExtResource("1_glb")]
; GLB is modeled ~1m tall facing -Z. Scale up so it reads as a real
; threat and is bigger than Mario's head — earlier 0.55 scale made
; it tiny and hard to land a stomp on.
transform = Transform3D(1.4, 0, 0, 0, 1.4, 0, 0, 0, 1.4, 0, 0.5, 0)
