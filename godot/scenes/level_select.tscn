[ext_resource type="Script" path="res://scripts/level_select.gd" id="1_ls"]

; Intermediate menu between the landing page and the game. Lists every
; level currently available — both built .tscn levels in
; assets/levels/ and JSON blueprints in /home/david/gd_mario/blueprints/
; that haven't been built yet (those auto-build on click). The runtime
; loader reads `level_select.gd.pending_level` to know what to boot.

